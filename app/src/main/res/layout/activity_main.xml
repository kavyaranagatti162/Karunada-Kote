<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/parchment_bg">

    <!-- Historic Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/parchment_dark"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ಶುಭೋದಯ • Good Morning"
            android:textColor="@color/parchment_light"
            android:textSize="13sp"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ಕರ್ನಾಡ ಕೋಟೆ ಗೈಡ್"
            android:textColor="@color/royal_gold"
            android:textSize="26sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Your Fort to Begin"
            android:textColor="@color/parchment_cream"
            android:textSize="14sp"
            android:fontFamily="serif"
            android:layout_marginTop="2dp" />

        <!-- Gold divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/royal_gold"
            android:layout_marginTop="12dp"
            android:alpha="0.5" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚔  Karnataka's Forts"
        android:textColor="@color/parchment_mid"
        android:textSize="12sp"
        android:fontFamily="serif"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_forts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
