<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/parchment_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View android:layout_width="match_parent" android:layout_height="3dp"
            android:background="@color/parchment_mid" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_challenge_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Hero's Crevice"
                android:textColor="@color/parchment_dark"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_challenge_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Find the Onake Obavva Kindi and photograph it."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:id="@+id/tv_challenge_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hint: Look near the eastern wall."
                android:textColor="@color/royal_gold_dark"
                android:textSize="12sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Take Photo"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:layout_marginTop="12dp"
                style="@style/Widget.KarunadaKote.Button" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
