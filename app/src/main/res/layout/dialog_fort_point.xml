<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/parchment_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/parchment_dark"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_point_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ellamarasamma Gate"
                        android:textColor="@color/parchment_cream"
                        android:textSize="18sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_point_title_kn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ಎಲ್ಲಮ್ಮರಸಮ್ಮ ದ್ವಾರ"
                        android:textColor="@color/royal_gold"
                        android:textSize="14sp"
                        android:fontFamily="serif"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_visited_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Visited"
                    android:textColor="@color/visited_green"
                    android:textSize="12sp"
                    android:fontFamily="serif"
                    android:background="@drawable/badge_visited_bg"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btn_close_dialog"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="@android:color/transparent"
                    android:contentDescription="Close"
                    android:tint="@color/parchment_light"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Decorative divider -->
        <View android:layout_width="match_parent" android:layout_height="2dp"
            android:background="@color/royal_gold" />

        <!-- History text -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp">
            <TextView
                android:id="@+id/tv_point_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="History text goes here..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:lineSpacingExtra="4dp"
                android:padding="16dp" />
        </ScrollView>

        <!-- Listen button -->
        <Button
            android:id="@+id/btn_listen"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:text="🔊  Listen to the Story"
            android:textSize="15sp"
            android:fontFamily="serif"
            style="@style/Widget.KarunadaKote.Button" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
