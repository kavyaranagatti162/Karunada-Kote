<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/parchment_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/parchment_dark"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_challenge_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHOTO CHALLENGES"
                    android:textColor="@color/royal_gold"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="serif" />

                <TextView
                    android:id="@+id/tv_challenge_fort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chitradurga Fort"
                    android:textColor="@color/parchment_cream"
                    android:textSize="18sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_challenge_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/3"
                android:textColor="@color/royal_gold"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/royal_gold" android:layout_marginTop="12dp" android:alpha="0.4" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find these spots and photograph them to unlock Karnataka's heritage!"
            android:textColor="@color/parchment_light"
            android:textSize="12sp"
            android:fontFamily="serif"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_challenges"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false" />
</LinearLayout>
