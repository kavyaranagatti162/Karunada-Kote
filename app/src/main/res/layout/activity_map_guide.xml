<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map fills full screen -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/audio_player_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top overlay bar -->
    <LinearLayout
        android:id="@+id/map_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/map_top_bar_bg"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_map_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/circle_button_bg"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GUIDED TOUR"
                android:textColor="@color/royal_gold"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/tv_map_fort_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chitradurga Fort"
                android:textColor="@color/parchment_cream"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Language toggle -->
        <ToggleButton
            android:id="@+id/toggle_lang"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:textOn="ಕನ್ನಡ"
            android:textOff="ENG"
            android:textSize="11sp"
            android:textColorOn="@color/parchment_dark"
            android:textColorOff="@color/parchment_cream"
            android:background="@drawable/toggle_lang_bg" />
    </LinearLayout>

    <!-- Map Legend -->
    <LinearLayout
        android:id="@+id/map_legend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/legend_bg"
        android:padding="8dp"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toTopOf="@id/audio_player_panel"
        app:layout_constraintStart_toStartOf="parent">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔴 Gate  🟠 Temple"
            android:textSize="10sp" android:textColor="@color/parchment_dark" android:fontFamily="serif" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔵 Tower  🩵 Well"
            android:textSize="10sp" android:textColor="@color/parchment_dark" android:fontFamily="serif" android:layout_marginTop="3dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🟢 Visited"
            android:textSize="10sp" android:textColor="@color/visited_green" android:fontFamily="serif" android:layout_marginTop="3dp"/>
    </LinearLayout>

    <!-- Audio Player Panel (slides up from bottom) -->
    <LinearLayout
        android:id="@+id/audio_player_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/parchment_dark"
        android:padding="14dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gold top border -->
        <View android:layout_width="match_parent" android:layout_height="2dp"
            android:background="@color/royal_gold" android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_audio_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ellamarasamma Gate"
            android:textColor="@color/royal_gold"
            android:textSize="15sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <SeekBar
            android:id="@+id/seekbar_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:progressTint="@color/royal_gold"
            android:thumbTint="@color/royal_gold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_audio_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00 / 0:00"
                android:textColor="@color/parchment_light"
                android:textSize="12sp"
                android:fontFamily="serif" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_pause"
                android:background="@drawable/circle_button_bg_gold"
                android:contentDescription="Play/Pause" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
