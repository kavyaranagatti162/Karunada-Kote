<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/parchment_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/parchment_dark">

            <!-- Decorative fort pattern overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.15"
                android:background="@drawable/bg_fort_pattern" />

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="12dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="Back" />

            <!-- Fort name overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom"
                android:padding="20dp"
                android:background="@drawable/gradient_bottom_dark">

                <TextView
                    android:id="@+id/tv_fort_name_kn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ಚಿತ್ರದುರ್ಗ ಕೋಟೆ"
                    android:textColor="@color/royal_gold"
                    android:textSize="16sp"
                    android:fontFamily="serif" />

                <TextView
                    android:id="@+id/tv_fort_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chitradurga Fort"
                    android:textColor="@color/parchment_cream"
                    android:textSize="24sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Gold bar -->
        <View android:layout_width="match_parent" android:layout_height="3dp"
            android:background="@color/royal_gold" />

        <!-- Info cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardBackgroundColor="@color/parchment_cream"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DYNASTY"
                        android:textColor="@color/parchment_mid"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="serif" />
                    <TextView android:id="@+id/tv_dynasty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nayaka"
                        android:textColor="@color/parchment_dark"
                        android:textSize="14sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardBackgroundColor="@color/parchment_cream"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BUILT"
                        android:textColor="@color/parchment_mid"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="serif" />
                    <TextView android:id="@+id/tv_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10th Century"
                        android:textColor="@color/parchment_dark"
                        android:textSize="14sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Description -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About This Fort"
                android:textColor="@color/parchment_dark"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:lineSpacingExtra="4dp" />

            <!-- Progress -->
            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Explored: 0 / 5 landmarks"
                android:textColor="@color/visited_green"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/btn_begin_tour"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⚔  Begin Guided Tour"
                android:textSize="16sp"
                android:fontFamily="serif"
                style="@style/Widget.KarunadaKote.Button"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_challenges"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📷  Photo Challenges"
                android:textSize="15sp"
                android:fontFamily="serif"
                style="@style/Widget.KarunadaKote.Button.Outlined" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
