<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/parchment_dark"
    android:padding="32dp">

    <!-- Fort silhouette icon -->
    <ImageView
        android:id="@+id/iv_splash_logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_fort_splash"
        android:contentDescription="Fort Icon" />

    <TextView
        android:id="@+id/tv_splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ಕರ್ನಾಡ ಕೋಟೆ ಗೈಡ್"
        android:textColor="@color/royal_gold"
        android:textSize="28sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:alpha="0" />

    <TextView
        android:id="@+id/tv_splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Karunada Kote Guide"
        android:textColor="@color/parchment_cream"
        android:textSize="20sp"
        android:fontFamily="serif"
        android:layout_marginTop="8dp"
        android:alpha="0" />

    <!-- Decorative divider -->
    <View
        android:layout_width="80dp"
        android:layout_height="1dp"
        android:background="@color/royal_gold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tv_splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ಕಲ್ಲಿನ ಕಥೆಗಳನ್ನು ಕೇಳು\nListen to the Stories in Stone"
        android:textColor="@color/parchment_light"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:alpha="0" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Karnataka Pride • ಕರ್ನಾಟಕ ಹೆಮ್ಮೆ"
        android:textColor="@color/parchment_mid"
        android:textSize="11sp"
        android:layout_marginTop="60dp" />

</LinearLayout>
